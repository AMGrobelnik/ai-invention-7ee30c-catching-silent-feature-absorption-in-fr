  "metadata": {
    "method_name": "A-Priori SAE Firing-Structure Router (combined firing-Jaccard AND recall-hole screen)",
    "description": "Per-concept label-free firing-structure ROUTER cards produced by the GPU forward pass (Gemma-Scope L12/16k SAE over gemma-2-2b). Each card carries the two a-priori signals (firing-Jaccard, recall-hole) and the held-out downstream AUCs of the label-free grouped unit vs three supervised baselines (a/h/d). This subset lets the router ANALYSIS layer be reproduced on CPU without re-running the SAE.",
    "baselines": {
      "a": "best single raw SAE latent (highest train AUC, content-responsive) \u2014 the individual latent to beat",
      "h": "supervised SAE standardized diff-of-means attribution pool (top-k, AxBench/SCR-TPP proxy)",
      "d": "non-SAE standardized diff-of-means probe on the raw layer-12 residual (required non-SAE baseline)",
      "unit": "label-free CCRG K-track-lite: parent anchor + firing-disjoint hole-covering absorbers"
    },
